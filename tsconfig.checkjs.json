{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": false,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "node",
    "lib": ["ES2022", "DOM"],
    "skipLibCheck": true
  },
  "include": [
    "web/state.js",
    "web/filters.js",
    "web/api.js",
    "web/ui-map.js",
    "web/app.js",
    "web/global.d.ts"
  ]
}
